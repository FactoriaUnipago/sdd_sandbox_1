{
  "_comment": "Vercel project configuration — NOT a CI/CD pipeline. Vercel reads this from the repo directly.",
  "_usage": "Copy the variant matching your deployment.pattern. Remove the wrapper key. Save as vercel.json in project root.",

  "fullstack-vercel (Next.js)": {
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "nextjs",
    "buildCommand": "npm run build",
    "installCommand": "npm install",
    "outputDirectory": ".next",
    "rewrites": [
      { "source": "/api/:path*", "destination": "/api/:path*" }
    ],
    "headers": [
      {
        "source": "/api/(.*)",
        "headers": [
          { "key": "Cache-Control", "value": "no-store, must-revalidate" }
        ]
      },
      {
        "source": "/(.*)",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" }
        ]
      }
    ],
    "env": {
      "DATABASE_URL": "@database-url",
      "NODE_ENV": "production"
    }
  },

  "fullstack-vercel (Vite + Express)": {
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "vite",
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "rewrites": [
      { "source": "/api/:path*", "destination": "/api/:path*" }
    ],
    "headers": [
      {
        "source": "/(.*)",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" }
        ]
      }
    ],
    "env": {
      "DATABASE_URL": "@database-url",
      "VITE_API_URL": "@api-url"
    }
  },

  "monorepo-split": {
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "rootDirectory": "frontend",
    "framework": "vite",
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "headers": [
      {
        "source": "/(.*)",
        "headers": [
          { "key": "X-Content-Type-Options", "value": "nosniff" },
          { "key": "X-Frame-Options", "value": "DENY" }
        ]
      }
    ],
    "env": {
      "VITE_API_URL": "@api-url"
    },
    "_note": "rootDirectory apunta al frontend. El backend se deploya a AWS via GH Actions."
  },

  "frontend-only": {
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": "vite",
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "redirects": [
      { "source": "/old-route", "destination": "/new-route", "permanent": true }
    ],
    "headers": [
      {
        "source": "/assets/(.*)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  }
}
