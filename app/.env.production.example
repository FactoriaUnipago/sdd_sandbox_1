# Production Server Configuration
PORT=3000

# AWS RDS PostgreSQL 16 connection string (enforced SSL)
# Format: postgresql://[user]:[password]@[endpoint]:[port]/[database]?sslmode=require
DATABASE_URL="postgresql://dbadmin:YOUR_AWS_SECRETS_PASSWORD@YOUR_RDS_ENDPOINT_HERE:5432/taskdb?sslmode=require"

# Production API Security Keys (Must be long, random, and configured in your environment host)
API_KEY="generate-a-long-random-api-key-for-production"
JWT_SECRET="generate-a-secure-high-entropy-jwt-signing-secret"

# Production Frontend URL (CORS policy)
CORS_ORIGIN="https://task-manager-sdd.vercel.app"
