{
  "name": "task-manager-server",
  "version": "1.0.0",
  "description": "Task Manager Express Server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "db:migrate": "prisma migrate dev",
