# Server configuration
PORT=3000

# Database URL for Prisma (default points to local docker setup)
DATABASE_URL="postgresql://admin:adminpassword@localhost:5432/taskdb?schema=public"

# Security
API_KEY="your-local-dev-api-key-here"
JWT_SECRET="your-super-secret-jwt-secret-key-here-must-be-long-and-secure"

# CORS configuration
CORS_ORIGIN="http://localhost:5173"
